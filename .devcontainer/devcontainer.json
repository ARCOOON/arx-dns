{
  "name": "arx-dns-development",
  "image": "mcr.microsoft.com/devcontainers/base:debian",
  "features": {
    "ghcr.io/devcontainers/features/go:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "workspaceFolder": "/workspaces/arx-dns",
  "remoteUser": "vscode",
  "containerUser": "vscode",
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_BIND_SERVICE",
    "--sysctl=net.ipv4.ip_unprivileged_port_start=0"
  ],
  "appPort": [
    "53:53/udp",
    "53:53/tcp"
  ],
  "forwardPorts": [
    53,
    5173
  ],
  "portsAttributes": {
    "53": {
      "label": "DNS (UDP/TCP)",
      "onAutoForward": "silent",
      "requireLocalPort": true
    },
    "5173": {
      "label": "Vue dev server (Vite)",
      "onAutoForward": "notify"
    }
  },
  "containerEnv": {
    "CGO_ENABLED": "0",
    "GO111MODULE": "on"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.Go",
        "Vue.volar",
        "bradlc.vscode-tailwindcss",
        "tamasfe.even-better-toml",
        "yzhang.markdown-all-in-one",
        "davidanson.vscode-markdownlint",
        "bierner.markdown-mermaid"
      ],
      "settings": {
        "go.useLanguageServer": true,
        "go.toolsManagement.checkForUpdates": "local",
        "go.lintOnSave": "package",
        "editor.formatOnSave": true,
        "[go]": {
          "editor.defaultFormatter": "golang.Go"
        },
        "[markdown]": {
          "editor.wordWrap": "on"
        }
      }
    }
  },
  "postCreateCommand": "sudo npm install -g npm@latest pnpm@latest && sudo apt-get update && sudo apt-get install -y --no-install-recommends bind9-dnsutils dnsutils && go version && node --version && npm --version && pnpm --version"
}